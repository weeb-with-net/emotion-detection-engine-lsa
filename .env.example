# Copy this file to ".env" and fill in your real values.
# NEVER commit the actual ".env" file (it's already in .gitignore).

# Gemini API key from https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key_here

# Model directories (defaults match the folder structure below; change only if you moved things)
BILSTM_MODEL_DIR=models/bltsm
BERT_MODEL_DIR=models/bert_emotion_model_final

# Data directory
DATA_DIR=data

# CSV log file for interaction history / analytics dashboard
LOG_CSV_PATH=logs/interactions.csv
